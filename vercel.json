{
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "frontend/client/dist",
  "framework": "vite",
  "installCommand": "npm install",
  "functions": {
    "api/test-minimal.js": {
      "maxDuration": 30
    },
    "api/test-commonjs.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/test-minimal",
      "destination": "/api/test-minimal.js"
    },
    {
      "source": "/api/test-commonjs",
      "destination": "/api/test-commonjs.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}

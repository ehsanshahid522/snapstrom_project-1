{
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "frontend/client/dist",
  "framework": "vite",
  "installCommand": "npm install",
  "functions": {
    "api/test-minimal.js": {
      "maxDuration": 30
    },
    "api/test-commonjs.js": {
      "maxDuration": 30
    },
    "api/auth/login.js": {
      "maxDuration": 30
    },
    "api/auth/register.js": {
      "maxDuration": 30
    },
    "api/feed.js": {
      "maxDuration": 30
    },
    "api/data-check-commonjs.js": {
      "maxDuration": 30
    },
    "api/investigate-data.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/test-minimal",
      "destination": "/api/test-minimal.js"
    },
    {
      "source": "/api/test-commonjs",
      "destination": "/api/test-commonjs.js"
    },
    {
      "source": "/api/data-check",
      "destination": "/api/data-check-commonjs.js"
    },
    {
      "source": "/api/investigate",
      "destination": "/api/investigate-data.js"
    },
    {
      "source": "/api/auth/login",
      "destination": "/api/auth/login.js"
    },
    {
      "source": "/api/auth/register",
      "destination": "/api/auth/register.js"
    },
    {
      "source": "/api/feed",
      "destination": "/api/feed.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}

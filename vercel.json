{
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "frontend/client/dist",
  "framework": "vite",
  "installCommand": "npm install",
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, PUT, DELETE, OPTIONS, PATCH"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, Authorization, X-Requested-With, Accept, Origin"
        },
        {
          "key": "Access-Control-Allow-Credentials",
          "value": "true"
        },
        {
          "key": "Access-Control-Max-Age",
          "value": "86400"
        }
      ]
    }
  ],
  "functions": {
    "api/auth/login.js": {
      "maxDuration": 30
    },
    "api/auth/register.js": {
      "maxDuration": 30
    },
    "api/feed.js": {
      "maxDuration": 30
    },
    "api/upload.js": {
      "maxDuration": 30
    },
    "api/profile.js": {
      "maxDuration": 30
    },
    "api/like.js": {
      "maxDuration": 30
    },
    "api/users-search.js": {
      "maxDuration": 30
    },
    "api/chat.js": {
      "maxDuration": 30
    },
    "api/data-check-commonjs.js": {
      "maxDuration": 30
    },
    "api/create-sample-posts.js": {
      "maxDuration": 30
    },
    "api/cleanup-posts.js": {
      "maxDuration": 30
    },
    "api/cors-proxy.js": {
      "maxDuration": 10
    },
    "api/test-all.js": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/api/data-check",
      "destination": "/api/data-check-commonjs.js"
    },
    {
      "source": "/api/create-sample-posts",
      "destination": "/api/create-sample-posts.js"
    },
    {
      "source": "/api/cleanup-posts",
      "destination": "/api/cleanup-posts.js"
    },
    {
      "source": "/api/auth/login",
      "destination": "/api/auth/login.js"
    },
    {
      "source": "/api/auth/register",
      "destination": "/api/auth/register.js"
    },
    {
      "source": "/api/feed",
      "destination": "/api/feed.js"
    },
    {
      "source": "/api/upload",
      "destination": "/api/upload.js"
    },
    {
      "source": "/api/profile/(.*)",
      "destination": "/api/profile.js"
    },
    {
      "source": "/api/like/(.*)",
      "destination": "/api/like.js"
    },
    {
      "source": "/api/follow/(.*)",
      "destination": "/api/profile.js"
    },
    {
      "source": "/api/users/search",
      "destination": "/api/users-search.js"
    },
    {
      "source": "/api/chat/(.*)",
      "destination": "/api/chat.js"
    },
    {
      "source": "/api/cors-proxy/(.*)",
      "destination": "/api/cors-proxy.js"
    },
    {
      "source": "/api/test-all",
      "destination": "/api/test-all.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}